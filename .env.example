NODE_ENV=development
PORT=8000
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST.neon.tech/DATABASE?sslmode=require"
DATABASE_POOL_MAX=5
DATABASE_CONNECT_TIMEOUT_MS=15000
DATABASE_IDLE_TIMEOUT_MS=30000
JWT_SECRET="replace-with-a-random-secret-at-least-32-characters-long"
JWT_EXPIRES_IN=7d
# Recommended: point to the downloaded Firebase service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"

# Alternative to GOOGLE_APPLICATION_CREDENTIALS:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
CORS_ORIGIN=http://localhost:5173,http://localhost:47831
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Multi-provider AI router. The first configured healthy provider is used,
# then failures automatically fall through to the next provider.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
TOGETHER_API_KEY=
TOGETHER_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# Razorpay subscriptions
RAZORPAY_KEY_ID="rzp_test_or_live_key_id"
RAZORPAY_KEY_SECRET="replace-with-razorpay-key-secret"
