NODE_ENV=production
PORT=8000
DATABASE_URL="postgresql://USER:PASSWORD@PRODUCTION_POOLER_HOST/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@PRODUCTION_DIRECT_HOST/DATABASE?sslmode=require"
DATABASE_POOL_MAX=5
DATABASE_CONNECT_TIMEOUT_MS=15000
DATABASE_IDLE_TIMEOUT_MS=30000
JWT_SECRET="replace-with-a-random-production-secret-at-least-32-characters-long"
JWT_EXPIRES_IN=7d
GOOGLE_APPLICATION_CREDENTIALS="/secure/path/to/production-service-account.json"
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
CORS_ORIGIN=https://interviewmate.ai,https://app.interviewmate.ai
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TRANSCRIPTION_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
OPENROUTER_TRANSCRIPTION_MODEL=google/gemini-2.0-flash-001
TOGETHER_API_KEY=
TOGETHER_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
TOGETHER_TRANSCRIPTION_MODEL=openai/whisper-large-v3
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
HUGGINGFACE_TRANSCRIPTION_MODEL=openai/whisper-large-v3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_CODING_MODEL=
OPENAI_DEFAULT_MODEL=
OPENAI_DEBUGGING_MODEL=
OPENAI_VISION_MODEL=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
AI_PROVIDER_PRIORITY=openai,groq,gemini,openrouter,together,huggingface
AI_PROVIDER_TIMEOUT_MS=25000
AI_PROVIDER_COOLDOWN_MS=60000
RAZORPAY_KEY_ID="rzp_live_key_id"
RAZORPAY_KEY_SECRET="replace-with-production-razorpay-secret"
